{
   "browser_action": {
      "default_icon": "icon-48x48.png",
      "default_popup": "popup.html"
   },
   "content_scripts": [ {
      "all_frames": true,
      "js": [ "content_main.js" ],
      "matches": [ "\u003Call_urls>" ]
   } ],
